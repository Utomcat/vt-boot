<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.ranyk.vt.boot.example.satoken.repository.department.DepartmentAccountConnectionRepository">

    <!-- 根据部门ID批量删除部门账户关联关系数据 -->
    <delete id="deleteByDepartmentId">
        delete from department_account_connection dac where dac.department_id = #{departmentId}
    </delete>

    <!-- 根据部门ID列表批量删除部门账户关联关系数据 -->
    <delete id="deleteByDepartmentIdIn">
        delete from department_account_connection dac
        where dac.department_id in
        <foreach item="item" index="index" collection="departmentIds" separator="," open="(" close=")">
            #{item}
        </foreach>
    </delete>
</mapper>