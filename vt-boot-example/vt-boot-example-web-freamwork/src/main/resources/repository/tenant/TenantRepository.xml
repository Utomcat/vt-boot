<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.ranyk.vt.boot.example.web.freamwork.repository.tenant.TenantRepository">
    <!-- 依据条件 = name and != id 统计租户数据的数量 -->
    <select id="selectCountByNameEqAndIdNotEq" resultType="java.lang.Integer">
        select count(1) from tenant_info ti where ti.name = #{name} and ti.id != #{id}
    </select>

    <!-- 依据条件 = code and != id 统计租户数据的数量 -->
    <select id="selectCountByCodeEqAndIdNotEq" resultType="java.lang.Integer">
        select count(1) from tenant_info ti where ti.code = #{code} and ti.id != #{id}
    </select>
</mapper>